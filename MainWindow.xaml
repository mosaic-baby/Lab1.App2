<Window x:Class="Lab1.App2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab1.App2"
        mc:Ignorable="d"
        Title="MainWindow" Height="150" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Button Content="Добавить" Click="MyButton_Click" HorizontalAlignment="Left" Margin="49,10,0,0" Grid.Row="1" VerticalAlignment="Top" Height="34" Width="165" Command="{Binding AddItemCommand}" />
        <TextBox HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" Width="165" Height="24" Margin="49,0,0,0" x:Name="line1" Text="{Binding NewText, UpdateSourceTrigger=PropertyChanged}" />
        <Border BorderBrush="Black" BorderThickness="1" Grid.ColumnSpan="2" Margin="240,11,52,10" Grid.RowSpan="2">
            <ListBox d:ItemsSource="{d:SampleData ItemCount=0}" x:Name="line2" ItemsSource="{Binding ItemsCollection}" />
        </Border>

    </Grid>
</Window>
